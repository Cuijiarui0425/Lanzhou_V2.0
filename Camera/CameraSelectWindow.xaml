<Window x:Class="Lanzhou_v1._0.Camera.CameraSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择相机" Height="360" Width="520" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="Gray" TextWrapping="Wrap"
                   Text="点击“刷新”扫描可用相机；选中设备后点击“连接”。（相机通过 USB/网口接入均可）"/>

        <Border Grid.Row="1" Margin="0,10,0,10" BorderThickness="1" CornerRadius="6" Padding="6">
            <ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"/>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button Width="90" Height="32" Margin="0,0,8,0" Content="刷新" Click="Refresh_Click"/>
            <DockPanel DockPanel.Dock="Right">
                <Button Width="90" Height="32" Margin="0,0,8,0" Content="取消" Click="Cancel_Click"/>
                <Button Width="90" Height="32" Content="连接" Click="Ok_Click"/>
            </DockPanel>
        </DockPanel>
    </Grid>
</Window>
