<Window x:Class="Lanzhou_v1._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:local="clr-namespace:Lanzhou_v1._0"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="微牵引力摩擦膜原位测量系统 HMI"
        Width="1500"
        Height="1020"
        MinWidth="1340"
        MinHeight="920"
        WindowStartupLocation="CenterScreen">

    <!--
    ======================================================================
    MainWindow.xaml 主界面说明（仅注释，不改变任何绑定/布局）
    ======================================================================
    目标：承载 HMI 主界面布局；数据与命令来自 MainViewModel（MVVM）。
    关键点：
      1) Button.Command 绑定 ViewModel 的 ICommand（例如 ConnectCmd）
      2) TextBlock/StatusBarItem 绑定 ViewModel 属性（例如 PlcStatusText）
      3) OxyPlot PlotView.Model 绑定 ViewModel 的 PlotModel（例如 PlotMu）
    页面分区（从上到下）：
      A 顶栏状态条：PLC/DAQ/模式/运行状态/报警/Probe
      B 顶部标题 + 试验计时
      C 中部三栏：左 命令区，中 参数区，右 实时显示与采集配置
      D 底部曲线：t-μ 与 t-载荷（含线性/对数切换）
    -->


    <Window.Resources>
        <!-- ========================= 窗口与布局参数（可调） ========================= -->
        <!-- 说明：纯 XAML 无法对资源做“求和”计算，因此 WinDefault/MinWidth/Height 以预先计算的常值给出；
             如需随 WLeft/WMidMin/WRightCol 等自动联动，请在 code-behind 或 Converter 中计算。 -->

        <!-- 宽度：左/右固定；中间吃剩余且有下限 -->
        <GridLength x:Key="WLeft">360</GridLength>
        <GridLength x:Key="WRightCol">200</GridLength>
        <sys:Double  x:Key="WMidMin">520</sys:Double>
        <sys:Double  x:Key="WMidDefault">680</sys:Double>
        <sys:Double  x:Key="PadX">60</sys:Double>
        <sys:Double  x:Key="WinMinWidth">1340</sys:Double>
        <!-- = 360 + 520 + 400 + 60 -->
        <sys:Double  x:Key="WinDefaultWidth">1500</sys:Double>
        <!-- = 360 + 680 + 400 + 60 -->

        <!-- 高度：标题+中部控制区总高度固定；曲线区吃剩余且保证下限 -->
        <GridLength x:Key="HeaderHeight">42</GridLength>
        <GridLength x:Key="ControlAreaHeight">480</GridLength>
        <sys:Double  x:Key="PlotMinHeight">320</sys:Double>
        <sys:Double  x:Key="PadY">60</sys:Double>
        <sys:Double  x:Key="WinMinHeight">920</sys:Double>
        <!-- = 72 + 480 + 320 + 48(近似) -->
        <sys:Double  x:Key="WinDefaultHeight">1020</sys:Double>
        <!-- 默认略高，给曲线区更多空间 -->

        <!-- 三列“上块”高度独立控制（像素定值，可按需要修改） -->
        <GridLength x:Key="LeftTopHeight">160</GridLength>
        <GridLength x:Key="MidTopHeight">240</GridLength>
        <GridLength x:Key="RightTopHeight">260</GridLength>

        <!-- 参数输入区：标签/输入框统一宽度（用于解决：输入框过宽、与变量名间距过大） -->
        <GridLength x:Key="ParamLabelColWidth">160</GridLength>
        <GridLength x:Key="ParamInputColWidth">150</GridLength>
        <sys:Double  x:Key="ParamInputWidth">120</sys:Double>
        <sys:Double  x:Key="ParamSelectWidth">160</sys:Double>

        <Style x:Key="ParamTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="{StaticResource ParamInputWidth}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ParamComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Width" Value="{StaticResource ParamSelectWidth}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ParamCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ================= 模式绑定的参数面板模板 ================= -->
        <DataTemplate x:Key="TplP22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="设定载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="0" Grid.Column="1" Margin="0,0,8,6" IsEnabled="False"
                         ToolTip="设定载荷由加载系统带入（加载达标时锁存），此处不可修改。"
                         Text="{Binding ManualLoadSetForMotion, Mode=OneWay}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,6" Foreground="Gray" Text="恒速：P22球/盘共同运行；设定载荷由加载系统带入。"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球速 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" Text="{Binding BallSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘速 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" Text="{Binding DiskSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球工作时间 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" Text="{Binding BallWorkTimeSet, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="盘工作时间 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="4" Grid.Column="1" Margin="0,0,8,0" Text="{Binding DiskWorkTimeSet, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TplP24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="设定载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="0" Grid.Column="1" Margin="0,0,8,6" IsEnabled="False"
                         ToolTip="设定载荷由加载系统带入（加载达标时锁存），此处不可修改。"
                         Text="{Binding ManualLoadSetForMotion, Mode=OneWay}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,6" Foreground="Gray" Text="往复/间歇：速度2=0 可等效停歇；设定载荷由加载系统带入。"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球速1 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" Text="{Binding BallSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球速2 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" Text="{Binding BallSpeed2Set, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘速1 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" Text="{Binding DiskSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘速2 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="4" Grid.Column="1" Margin="0,0,8,6" Text="{Binding DiskSpeed2Set, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="阶段时间1 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="5" Grid.Column="1" Margin="0,0,8,6" Text="{Binding StageTime1Set, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="阶段时间2 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="6" Grid.Column="1" Margin="0,0,8,0" Text="{Binding StageTime2Set, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TplJog">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Ball dir -->
                    <RowDefinition Height="Auto"/>
                    <!-- Ball speed -->
                    <RowDefinition Height="Auto"/>
                    <!-- Disk dir -->
                    <RowDefinition Height="Auto"/>
                    <!-- Disk speed -->
                    <RowDefinition Height="Auto"/>
                    <!-- Press dir -->
                    <RowDefinition Height="Auto"/>
                    <!-- Press speed -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== 球点动方向（同一行） ==================== -->
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球_点动方向"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,6">
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}" Margin="0,0,12,0"
                      Content="正向" IsChecked="{Binding BallJogForward, UpdateSourceTrigger=PropertyChanged}"/>
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}"
                      Content="反向" IsChecked="{Binding BallJogReverse, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,6" Foreground="Gray"
                   Text="点动：按住对应按钮开始，松开停止；不需要设定载荷。"/>

                <!-- ==================== 球点动速度 ==================== -->
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球_点动速度 (mm/s)"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,6"
                 Style="{StaticResource ParamTextBoxStyle}"
                 Text="{Binding BallJogSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- ==================== 盘点动方向（同一行） ==================== -->
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘_点动方向"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,6">
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}" Margin="0,0,12,0"
                      Content="正向" IsChecked="{Binding DiskJogForward, UpdateSourceTrigger=PropertyChanged}"/>
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}"
                      Content="反向" IsChecked="{Binding DiskJogReverse, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- ==================== 盘点动速度 ==================== -->
                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘_点动速度 (mm/s)"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,8,6"
                 Style="{StaticResource ParamTextBoxStyle}"
                 Text="{Binding DiskJogSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- ==================== 下压点动方向（同一行） ==================== -->
                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="下压_点动方向"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,6">
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}" Margin="0,0,12,0"
                      Content="正向" IsChecked="{Binding PressJogForward, UpdateSourceTrigger=PropertyChanged}"/>
                    <CheckBox Style="{StaticResource ParamCheckBoxStyle}"
                      Content="反向" IsChecked="{Binding PressJogReverse, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- ==================== 下压点动速度 ==================== -->
                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="下压_点动速度 (mm/s)"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,8,0"
                 Style="{StaticResource ParamTextBoxStyle}"
                 Text="{Binding PressJogSpeedSet, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>


        <DataTemplate x:Key="TplLoadSystem">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="设定载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,8,0" Text="{Binding LoadNSet, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,0,0" Foreground="Gray" TextWrapping="Wrap"
                       Text="加载系统：输入设定载荷后，点击‘执行’。"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TplP26">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Width="180" VerticalAlignment="Center" Text="阶梯段数 (1~16)"/>
                    <TextBox Style="{StaticResource ParamTextBoxStyle}" Width="80" Text="{Binding P26StepCount, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Margin="10,0,0,0" Foreground="Gray" VerticalAlignment="Center" Text="仅下发前 N 行；其余段清零避免残留。"/>
                </DockPanel>


                <WrapPanel Margin="0,0,0,8">
                    <Button Margin="0,0,8,0" Height="28" Padding="10,0" Content="复制第1行→前N段" Command="{Binding P26CopyFirstRowCmd}"/>
                    <Button Margin="0,0,8,0" Height="28" Padding="10,0" Content="线性生成(1→N)" Command="{Binding P26LinearGenerateCmd}"/>
                    <Button Margin="0,0,8,0" Height="28" Padding="10,0" Content="从剪贴板粘贴" Command="{Binding P26PasteCmd}"/>
                    <Button Margin="0,0,8,0" Height="28" Padding="10,0" Content="清空后N段" Command="{Binding P26ClearTailCmd}"/>
                    <TextBlock Margin="10,4,0,0" Foreground="Gray" VerticalAlignment="Center" Text="可从 Excel 复制 4 列（球速/盘速/时间/载荷）后点“粘贴”。"/>
                </WrapPanel>

                <DataGrid ItemsSource="{Binding P26Steps}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" Height="220">
                    <!--
                        方案A（可直接编辑）实现要点：
                        1) DataGrid 允许原地编辑
                        2) 超出 N（阶梯段数）的行通过 IsActive 置灰/禁用，避免误改
                        3) 启用绑定异常校验 + NotifyDataErrors，非法输入在单元格处直接红框提示
                    -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="IsEnabled" Value="{Binding IsActive}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="Foreground" Value="Gray"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Width="40" IsReadOnly="True" Binding="{Binding Index}"/>
                        <DataGridTextColumn Header="球速 (mm/s)" Width="*" Binding="{Binding BallSpeed, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        <DataGridTextColumn Header="盘速 (mm/s)" Width="*" Binding="{Binding DiskSpeed, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        <DataGridTextColumn Header="时间 (s)" Width="*" Binding="{Binding TimeSeconds, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                        <DataGridTextColumn Header="载荷 (N)" Width="*" Binding="{Binding LoadN, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="TplAuto1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="循环次数"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="0" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto1CycleCount, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="实验载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto1TestLoad, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="拍照载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto1PhotoLoad, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="工作时间 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto1WorkTime, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="球速 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="4" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto1BallSpeed, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="盘速 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="5" Grid.Column="1" Margin="0,0,8,0" Text="{Binding Auto1DiskSpeed, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TplAuto2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ParamLabelColWidth}"/>
                    <ColumnDefinition Width="{StaticResource ParamInputColWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 输入参数（HMI -> PLC） -->
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="循环次数"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="0" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto2CycleCount, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="实验载荷 (N)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto2TestLoad, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="阶段时间 (s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto2StageTime, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘速最大值 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto2DiskMaxSpeed, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="盘速最小值 (mm/s)"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="4" Grid.Column="1" Margin="0,0,8,6" Text="{Binding Auto2DiskMinSpeed, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="SRR"/>
                <TextBox Style="{StaticResource ParamTextBoxStyle}"  Grid.Row="5" Grid.Column="1" Margin="0,0,8,0" Text="{Binding Auto2Srr, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- 只读块：放在你图里标红框的位置（右侧大空白区域） -->
                <Border Grid.Row="0" Grid.RowSpan="6" Grid.Column="2"
                Margin="0,0,0,0" Padding="10"
                Background="#FFF7F7F7"
                BorderBrush="#FFDDDDDD" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Auto2StateText}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Auto2PointProgressText}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Auto2CurrentTargetText}" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <TextBlock Text="{Binding Auto2EffectiveTimeText}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Auto2AvgForceText}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Auto2AvgMuText}" Margin="0,0,0,10"/>

                        <Button Height="34" Width="160" HorizontalAlignment="Left"
                        Content="导出 Auto2 CSV"
                        Command="{Binding ExportAuto2Cmd}"/>

                        <TextBlock Margin="0,8,0,0" Foreground="Gray" TextWrapping="Wrap"
                           Text="说明：Auto2 的 SingleDone 为脉冲型；HMI 通过上升沿划分点位并自算平均值，只向 PLC 回写 DataDone 脉冲。"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TplRunDefault">
            <UniformGrid Columns="2" Rows="2" Margin="12">
                <Button Margin="6" Height="70" FontSize="18" Content="启动" Command="{Binding StartCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="停止" Command="{Binding StopCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="复位" Command="{Binding ResetAlarmCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="急停" Command="{Binding EStopCmd}"/>
            </UniformGrid>
        </DataTemplate>

        <DataTemplate x:Key="TplRunLoadSystem">
            <UniformGrid Columns="3" Rows="1" Margin="12">
                <Button Margin="6" Height="70" FontSize="18" Content="执行" Command="{Binding PressLoadCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="复位" Command="{Binding PressResetCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="急停" Command="{Binding EStopCmd}"/>
            </UniformGrid>
        </DataTemplate>

        <DataTemplate x:Key="TplRunJog">
            <UniformGrid Columns="3" Rows="2" Margin="12">
                <Button Margin="6" Height="70" FontSize="18" Content="球点动（按住）"
                        PreviewMouseLeftButtonDown="BallJog_Down"
                        PreviewMouseLeftButtonUp="BallJog_Up"
                        LostMouseCapture="BallJog_Up"/>
                <Button Margin="6" Height="70" FontSize="18" Content="盘点动（按住）"
                        PreviewMouseLeftButtonDown="DiskJog_Down"
                        PreviewMouseLeftButtonUp="DiskJog_Up"
                        LostMouseCapture="DiskJog_Up"/>
                <Button Margin="6" Height="70" FontSize="18" Content="下压点动（按住）"
                        PreviewMouseLeftButtonDown="PressJog_Down"
                        PreviewMouseLeftButtonUp="PressJog_Up"
                        LostMouseCapture="PressJog_Up"/>
                <Button Margin="6" Height="70" FontSize="18" Content="复位" Command="{Binding ResetAlarmCmd}"/>
                <Button Margin="6" Height="70" FontSize="18" Content="急停" Command="{Binding EStopCmd}"/>
                <Border Opacity="0"/>
            </UniformGrid>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- A 顶栏状态条：联调用关键状态一行可见 -->
        <StatusBar DockPanel.Dock="Top">
            <StatusBarItem Content="{Binding CurrentModeText}" />
            <Separator/>
            <StatusBarItem Content="{Binding RunStateText}" />
            <Separator/>
            <StatusBarItem Content="{Binding AlarmText}" />
        </StatusBar>

        <!-- 主布局：三行 Grid（标题行，中部三栏，底部曲线）
             重要：为避免“控制区按钮被曲线区挤压导致显示不全”，
             将中部控制区占比提高（Row1:Row2 = 2*:1*），曲线区自适应剩余空间。
        -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource HeaderHeight}"/>
                <RowDefinition Height="{StaticResource ControlAreaHeight}"/>
                <RowDefinition Height="*" MinHeight="{StaticResource PlotMinHeight}"/>
            </Grid.RowDefinitions>

            <!-- B 顶部标题 + 试验计时（右侧固定宽度，避免计时被挤掉） -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="微牵引力摩擦膜原位测量系统 上位机"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Margin="0,0,8,0" Text="试验计时:"/>
                    <TextBlock FontWeight="SemiBold"
                               MinWidth="110"
                               TextAlignment="Right"
                               Text="{Binding ElapsedText}"/>
                </StackPanel>
            </Grid>


            <!-- C 中部布局（L2 + R1）：左上连接/采集/使能；左下功能区加高并放大点动；中下运行与安全固定；右下保留记录/报警/导出 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource WLeft}"/>
                    <ColumnDefinition Width="*" MinWidth="{StaticResource WMidMin}"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <!-- ================= 左列：上（连接/使能/采集）+ 下（功能区/点动） ================= -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <!-- LeftTopHeight：修改此处即可独立调节“左上”高度（单位：px） -->
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 左上：连接与使能（2行×3列，节约高度） -->
                    <GroupBox Header="连接与使能" Grid.Row="0" Margin="0,0,0,8" HorizontalAlignment="Right" Width="352">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Grid.RowSpan="2" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Margin="4" Height="36" Content="PLC 连接" Command="{Binding ConnectCmd}"/>
                                <Button Grid.Row="0" Grid.Column="1" Margin="4" Height="36" Content="电机使能" Command="{Binding LoadCmd}"/>
                                <Button Grid.Row="0" Grid.Column="2" Margin="4" Height="36" Content="采集开始" Command="{Binding StartAcqCmd}"/>

                                <Button Grid.Row="1" Grid.Column="0" Margin="4" Height="36" Content="PLC 断开" Command="{Binding DisconnectCmd}"/>
                                <Button Grid.Row="1" Grid.Column="1" Margin="4" Height="36" Content="电机断开" Command="{Binding UnloadCmd}"/>
                                <Button Grid.Row="1" Grid.Column="2" Margin="4" Height="36" Content="采集停止" Command="{Binding StopAcqCmd}"/>
                            </Grid>

                            <!-- 状态与串口 -->
                            <StackPanel Grid.Row="2">
                                <StackPanel Orientation="Horizontal" Margin="4,0,4,6">
                                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="Gray" Text="COM 口"/>
                                    <TextBox Style="{StaticResource ParamTextBoxStyle}" Width="110"
                                 Text="{Binding SerialPortName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Margin="4,0,4,2" Foreground="Gray" Text="{Binding PlcStatusText}"/>
                                <TextBlock Margin="4,0,4,2" Foreground="Gray" Text="{Binding DaqStatusText}"/>
                                <TextBlock Margin="4,0,4,2" Foreground="Gray" Text="{Binding SerialStatusText}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- 左下：功能区（含点动按住） -->
                    <GroupBox Header="模式选择区" Grid.Row="1" Margin="0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <GroupBox Header="手动功能模式" Grid.Row="0">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                            Margin="4" Height="40"
                                            Content="加载系统"
                                            Command="{Binding SetModeLoadSystemCmd}"/>

                                    <Button Grid.Row="1" Grid.Column="0" Margin="4" Height="40"
                                            Content="点动"
                                            Command="{Binding SetModeJogCmd}"/>
                                    <Button Grid.Row="1" Grid.Column="1" Margin="4" Height="40"
                                            Content="恒速"
                                            Command="{Binding SetModeP22Cmd}"/>
                                    <Button Grid.Row="1" Grid.Column="2" Margin="4" Height="40"
                                            Content="往复/间歇"
                                            Command="{Binding SetModeP24Cmd}"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="自动功能模式" Grid.Row="1" Margin="0,8,0,0">
                                <UniformGrid Columns="3" Margin="8">
                                    <Button Margin="4" Height="40" Content="阶梯" Command="{Binding SetModeP26Cmd}"/>
                                    <Button Margin="4" Height="40" Content="自动：恒速载荷" Command="{Binding SetModeAuto1Cmd}"/>
                                    <Button Margin="4" Height="40" Content="自动：变速" Command="{Binding SetModeAuto2Cmd}"/>
                                </UniformGrid>
                            </GroupBox>
                        </Grid>
                    </GroupBox>
                </Grid>

                <!-- ================= 中列：上（参数输入）+ 下（运行与安全） ================= -->
                <Grid Grid.Column="1" Margin="0,0,8,0">
                    <Grid.RowDefinitions>
                        <!-- MidTopHeight：修改此处即可独立调节“中上”高度（单位：px） -->
                        <RowDefinition Height="{StaticResource MidTopHeight}"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 中上：参数输入区（模式参数 + 采集参数；已移除“备注”栏） -->
                    <GroupBox Header="参数输入区" Grid.Row="0" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="{Binding CurrentModeParamHeader}" Grid.Column="0" Margin="0,0,10,0">
                                    <ContentControl Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ContentTemplate" Value="{StaticResource TplP22}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.ManualP22Constant}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplP22}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.ManualP24RecipIntermittent}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplP24}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.Jog}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplJog}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.LoadSystem}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplLoadSystem}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.ManualP26Step}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplP26}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.AutoProgram1}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplAuto1}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.AutoProgram2}">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplAuto2}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </GroupBox>

                                <StackPanel Grid.Column="1">
                                    <GroupBox Header="采集参数（PCIe-1805，牵引力，0-10V）">
                                        <Grid Margin="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,0,0" Text="采样率 (Hz)"/>
                                            <TextBox Style="{StaticResource ParamTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SamplesPerSecond, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,0,0" Text="N点平均 (points)"/>
                                            <TextBox Style="{StaticResource ParamTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding AvgPoints, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </GroupBox>

                                    <!-- 串口载荷标定：Raw -> Load(N) = (Raw + Offset) * Scale -->
                                    <GroupBox Header="采集载荷（串口 COM6 通道1）" Margin="0,10,0,0">
                                        <Grid Margin="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,0,0" Text="偏移量 Offset"/>
                                            <TextBox Style="{StaticResource ParamTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SerialLoadOffset, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,0,0" Text="缩放倍数 Scale"/>
                                            <TextBox Style="{StaticResource ParamTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SerialLoadScale, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0" Foreground="Gray" TextWrapping="Wrap"
                                                       Text="载荷(N) = (Raw + Offset) × Scale；先加偏移再乘倍数，结果用于实时显示、曲线、μ计算及回写 PLC。"/>
                                        </Grid>
                                    </GroupBox>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </GroupBox>

                    <!-- 中下：运行与安全（高度固定，位置不随模式变化） -->
                    <GroupBox Header="运行与安全" Grid.Row="1" Height="220" VerticalAlignment="Bottom">
                        <ContentControl Content="{Binding}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource TplRunDefault}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.LoadSystem}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource TplRunLoadSystem}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:TrialMode.Jog}">
                                            <Setter Property="ContentTemplate" Value="{StaticResource TplRunJog}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </GroupBox>
                </Grid>

                <!-- ================= 右列：上（实时显示）+ 下（记录/报警/导出） ================= -->
                <Grid Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <!-- RightTopHeight：独立控制右上高度（单位：px） -->
                        <RowDefinition Height="280"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="实时显示" Grid.Row="0" HorizontalAlignment="Left" Width="470" Grid.ColumnSpan="2">
                        <TabControl Margin="10">
                            <TabItem Header="实时数据">
                                <StackPanel>

                                    <UniformGrid Columns="4" Margin="0,0,0,8">
                                        <Border Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="牵引力 (N)"/>
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding TractionForceText}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="牵引力系数"/>
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding MuText}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="载荷 (N)"/>
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding LoadText}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="温度 (°C)"/>
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding TemperatureText}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1.35*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="球速 (mm/s)"/>
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding BallSpeedText}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="盘速 (mm/s)"/>
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding DiskSpeedText}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="卷吸速度 (mm/s)"/>
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding RollingSpeedText}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3" Margin="4" Padding="8" BorderThickness="1" CornerRadius="6">
                                            <StackPanel>
                                                <TextBlock Foreground="Gray" Text="SRR"/>
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SrrText}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>


                                </StackPanel>
                            </TabItem>

                            <TabItem Header="相机（USB）">
                                <Grid Margin="6">
                                    <!-- 左：控制按钮（收窄并靠左集中） 右：实时预览画面 -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="134*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="97*"/>
                                        <ColumnDefinition Width="107*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Foreground="Gray" TextWrapping="Wrap" Text="{Binding CameraStatusText}" Margin="0,0,0,8"/>

                                        <!-- 四个按钮：宽度缩小，集中到左半部分 -->
                                        <Button Width="120" HorizontalAlignment="Left" Height="34" Margin="0,0,0,6" Content="连接并选择相机" Command="{Binding CameraConnectCmd}"/>
                                        <Button Width="120" HorizontalAlignment="Left" Height="34" Margin="0,0,0,6" Content="断开相机" Command="{Binding CameraDisconnectCmd}"/>
                                        <Button Width="120" HorizontalAlignment="Left" Height="34" Margin="0,0,0,6" Content="拍照并保存" Command="{Binding CameraCaptureCmd}"/>
                                        <Button Width="120" HorizontalAlignment="Left" Height="34" Content="打开照片文件夹" Command="{Binding OpenPhotoFolderCmd}"/>

                                        <Separator Margin="0,12,0,12"/>

                                        <TextBlock Foreground="Gray" Text="自动程序1（恒速载荷）：拍照与 Done 回写"/>
                                        <CheckBox Margin="0,6,0,0" Content="启用 Auto1 自动拍照（按 PLC 4x407 请求/0x319 完成握手）" IsChecked="{Binding Auto1AutoPhotoEnabled}"/>
                                        <TextBlock Margin="0,6,0,0" Foreground="Gray" TextWrapping="Wrap" Text="{Binding Auto1AutoPhotoStatusText}"/>
                                        <TextBlock Margin="0,10,0,0" Foreground="Gray" TextWrapping="Wrap" Text="{Binding LastPhotoPath}"/>
                                    </StackPanel>

                                    <!-- 右侧实时预览：补齐 BorderBrush，否则边框不显示 -->
                                    <Border Grid.Column="2" BorderThickness="1" BorderBrush="#FFB0B0B0" Background="#FFFFFFFF" CornerRadius="6" Padding="8" MinHeight="180" Margin="0,0,0,10" Grid.ColumnSpan="2">
                                        <Grid Margin="0,0,0,17">
                                            <Image Source="{Binding CameraPreviewImage}" Stretch="Uniform" Margin="0,0,0,0"/>
                                            <TextBlock Foreground="#88000000" FontSize="14" FontWeight="SemiBold"
                                                       Text="预览" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </GroupBox>

                    <GroupBox Header="记录状态 / 报警提示 / 快捷导出" Grid.Row="1" Grid.ColumnSpan="2" >
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">

                                <!-- ================= 醒目提示：PLC 拍照请求（4x407） ================= -->
                                <Border Margin="0,0,0,10" Padding="10" BorderThickness="1" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <!-- 仅在 Auto1（自动：恒定/恒速载荷）模式显示该指示灯 -->
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Background" Value="#FFF5F5F5"/>
                                            <Setter Property="BorderBrush" Value="#FFB0B0B0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAutoProgram1Mode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding IsPlcPhotoRequestActive}" Value="True">
                                                    <Setter Property="Background" Value="#FFFFE5E5"/>
                                                    <Setter Property="BorderBrush" Value="#FFCC0000"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Text="拍照请求"/>
                                        <Ellipse Grid.Column="2" Width="18" Height="18" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#FF909090"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlcPhotoRequestActive}" Value="True">
                                                            <Setter Property="Fill" Value="#FFCC0000"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <TextBlock Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="26" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="OFF"/>
                                                    <Setter Property="Foreground" Value="#FF606060"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlcPhotoRequestActive}" Value="True">
                                                            <Setter Property="Text" Value="ON"/>
                                                            <Setter Property="Foreground" Value="#FFCC0000"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Foreground="Gray" FontSize="12" Text="{Binding PlcPhotoRequestRawText}"/>
                                            <TextBlock Foreground="Gray" FontSize="12" Text="{Binding PlcPhotoReqSeenInfo}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <!-- 新增：报警详情（错误码/伺服报警码表 + 当前 PLC 状态位） -->
                                <TextBlock Margin="0,0,0,6" Foreground="Gray" TextWrapping="Wrap" Text="{Binding AlarmDetailText}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Foreground="Gray" VerticalAlignment="Center" Text="显示窗口(s):"/>
                                    <TextBox Style="{StaticResource ParamTextBoxStyle}" Width="80" Margin="8,0,0,0" Text="{Binding PlotWindowSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Foreground="Gray" VerticalAlignment="Center" Margin="12,0,0,0" Text="{Binding RecordingFileBriefText}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Margin="0,0,0,6" Foreground="Gray" Text="{Binding SampleCountText}"/>
                                <TextBlock Foreground="Gray" TextWrapping="Wrap" Text="{Binding PlcProbeText}"/>
                            </StackPanel>

                            <Button Grid.Row="1"
                        Margin="0,12,0,0"
                        Height="38"
                        Content="导出 CSV"
                        Command="{Binding ExportCsvCmd}"/>
                        </Grid>
                    </GroupBox>
                </Grid>

            </Grid>

            <!-- D 底部曲线区：单曲线分页 + X/Y 线性/对数切换（项目书要求） -->
            <GroupBox Grid.Row="2" Header="曲线显示" Margin="0,8,0,0">
                <TabControl Margin="8">

                    <TabItem Header="t-载荷">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="LoadTime|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="LoadTime|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="LoadTime|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="LoadTime|Y|Log"/>

                                <Separator Width="16"/>
                                <Button Width="90" Content="复位滚动" Command="{Binding ResetPlotScrollCmd}"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_LoadTime" Model="{Binding PlotLoad}" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="t-卷吸速度">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="RollingTime|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="RollingTime|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="RollingTime|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="RollingTime|Y|Log"/>

                                <Separator Width="16"/>
                                <Button Width="90" Content="复位滚动" Command="{Binding ResetPlotScrollCmd}"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_RollingTime" Model="{Binding PlotRollingSpeedTime}" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="t-温度">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="TempTime|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="TempTime|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="TempTime|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="TempTime|Y|Log"/>

                                <Separator Width="16"/>
                                <Button Width="90" Content="复位滚动" Command="{Binding ResetPlotScrollCmd}"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_TempTime" Model="{Binding PlotTemperatureTime}" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="t-牵引力系数">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="MuTime|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="MuTime|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="MuTime|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="MuTime|Y|Log"/>

                                <Separator Width="16"/>
                                <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="EMA τ(s):"/>
                                <TextBox Width="70" Margin="0,0,16,0"
                                         Text="{Binding MuPlotTauSec, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="中值窗口:"/>
                                <TextBox Width="60" Margin="0,0,0,0"
                                         Text="{Binding MuPlotMedianWindow, UpdateSourceTrigger=PropertyChanged}"/>

                                <Separator Width="16"/>
                                <Button Width="90" Content="复位滚动" Command="{Binding ResetPlotScrollCmd}"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_MuTime" Model="{Binding PlotMu}" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="卷吸速度-牵引力系数">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="SpeedMu|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="SpeedMu|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="SpeedMu|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="SpeedMu|Y|Log"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_SpeedMu" Model="{Binding PlotRollingSpeedMu}" />
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="SRR-牵引力系数">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="X轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="SrrMu|X|Linear"/>
                                <Button Width="80" Margin="0,0,16,0" Content="对数" Click="AxisScale_Click" Tag="SrrMu|X|Log"/>

                                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Y轴:"/>
                                <Button Width="80" Margin="0,0,6,0" Content="线性" Click="AxisScale_Click" Tag="SrrMu|Y|Linear"/>
                                <Button Width="80" Content="对数" Click="AxisScale_Click" Tag="SrrMu|Y|Log"/>
                            </StackPanel>
                            <oxy:PlotView x:Name="PV_SrrMu" Model="{Binding PlotSrrMu}" />
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </GroupBox>

        </Grid>
    </DockPanel>
</Window>
